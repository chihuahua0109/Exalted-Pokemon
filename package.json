{
  "name": "exalted-pokemons",
  "version": "1.0.0",
  "description": "Pokemon TCG inventory manager with TCGplayer market pricing and AI camera card scanning.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "tunnel": "cloudflared tunnel --url http://localhost:3000 --no-autoupdate",
    "ios:add": "cap add ios",
    "ios:sync": "cap sync ios",
    "ios:open": "cap open ios"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "selfsigned": "^5.5.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.6",
    "@capacitor/core": "^7.6.6",
    "@capacitor/ios": "^7.6.6",
    "tesseract.js": "^7.0.0"
  }
}
